{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CommandEnvelope",
  "description": "Incoming command envelope — the JSON payload on `.../cmnd/{name}/in`.",
  "type": "object",
  "required": [
    "issued_at",
    "payload",
    "ttl_sec",
    "uuid"
  ],
  "properties": {
    "issued_at": {
      "type": "string",
      "format": "date-time"
    },
    "payload": {
      "$ref": "#/definitions/CommandPayload"
    },
    "ttl_sec": {
      "type": "integer",
      "format": "uint64",
      "minimum": 0.0
    },
    "uuid": {
      "type": "string"
    }
  },
  "definitions": {
    "CommandPayload": {
      "oneOf": [
        {
          "description": "Payload for `get_config` — no fields needed.",
          "type": "object",
          "required": [
            "type"
          ],
          "properties": {
            "type": {
              "type": "string",
              "enum": [
                "GetConfig"
              ]
            }
          }
        },
        {
          "description": "Payload for `config_update` (placeholder).",
          "type": "object",
          "required": [
            "payload",
            "type"
          ],
          "properties": {
            "payload": true,
            "type": {
              "type": "string",
              "enum": [
                "ConfigUpdate"
              ]
            }
          }
        },
        {
          "description": "Payload for `modem_commands`.",
          "type": "object",
          "required": [
            "command",
            "type"
          ],
          "properties": {
            "command": {
              "type": "string"
            },
            "timeout_ms": {
              "type": [
                "integer",
                "null"
              ],
              "format": "uint32",
              "minimum": 0.0
            },
            "type": {
              "type": "string",
              "enum": [
                "ModemCommands"
              ]
            }
          }
        },
        {
          "description": "Payload for `update_request` (placeholder).",
          "type": "object",
          "required": [
            "type",
            "url",
            "version"
          ],
          "properties": {
            "type": {
              "type": "string",
              "enum": [
                "UpdateRequest"
              ]
            },
            "url": {
              "type": "string"
            },
            "version": {
              "type": "string"
            }
          }
        },
        {
          "description": "Payload for `restart`.",
          "type": "object",
          "required": [
            "target",
            "type"
          ],
          "properties": {
            "target": {
              "$ref": "#/definitions/RestartTarget"
            },
            "type": {
              "type": "string",
              "enum": [
                "Restart"
              ]
            }
          }
        }
      ]
    },
    "RestartTarget": {
      "description": "Target unit/operation for a `restart` command.",
      "type": "string",
      "enum": [
        "camera",
        "mavlink",
        "modem",
        "unitctl",
        "reboot"
      ]
    }
  }
}
