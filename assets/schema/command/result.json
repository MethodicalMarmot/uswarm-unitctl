{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CommandResultMsg",
  "description": "Command result published on `.../cmnd/{name}/result`. The `data` field contains a tagged `CommandResultData` enum (omitted when None).",
  "type": "object",
  "required": [
    "ok",
    "ts",
    "uuid"
  ],
  "properties": {
    "data": {
      "anyOf": [
        {
          "$ref": "#/definitions/CommandResultData"
        },
        {
          "type": "null"
        }
      ]
    },
    "error": {
      "type": [
        "string",
        "null"
      ]
    },
    "ok": {
      "type": "boolean"
    },
    "ts": {
      "type": "string",
      "format": "date-time"
    },
    "uuid": {
      "type": "string"
    }
  },
  "definitions": {
    "CameraConfig": {
      "type": "object",
      "required": [
        "bitrate",
        "camera_type",
        "device",
        "env_path",
        "flip",
        "framerate",
        "gcs_ip",
        "height",
        "remote_video_port",
        "width"
      ],
      "properties": {
        "bitrate": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0.0
        },
        "camera_type": {
          "type": "string"
        },
        "device": {
          "type": "string"
        },
        "env_path": {
          "type": "string"
        },
        "flip": {
          "type": "integer",
          "format": "uint8",
          "minimum": 0.0
        },
        "framerate": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0.0
        },
        "gcs_ip": {
          "type": "string"
        },
        "height": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0.0
        },
        "remote_video_port": {
          "type": "integer",
          "format": "uint16",
          "minimum": 0.0
        },
        "width": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0.0
        }
      }
    },
    "CommandResultData": {
      "oneOf": [
        {
          "description": "Result for `get_config` — returns the sanitized configuration.",
          "type": "object",
          "required": [
            "config",
            "type"
          ],
          "properties": {
            "config": {
              "$ref": "#/definitions/SafeConfig"
            },
            "type": {
              "type": "string",
              "enum": [
                "GetConfig"
              ]
            }
          }
        },
        {
          "description": "Result for `config_update` (placeholder).",
          "type": "object",
          "required": [
            "fields_received",
            "message",
            "type"
          ],
          "properties": {
            "fields_received": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "message": {
              "type": "string"
            },
            "type": {
              "type": "string",
              "enum": [
                "ConfigUpdate"
              ]
            }
          }
        },
        {
          "description": "Result for `modem_commands`.",
          "type": "object",
          "required": [
            "command",
            "response",
            "type"
          ],
          "properties": {
            "command": {
              "type": "string"
            },
            "response": {
              "type": "string"
            },
            "type": {
              "type": "string",
              "enum": [
                "ModemCommands"
              ]
            }
          }
        },
        {
          "description": "Result for `update_request` (placeholder).",
          "type": "object",
          "required": [
            "message",
            "type",
            "version"
          ],
          "properties": {
            "message": {
              "type": "string"
            },
            "type": {
              "type": "string",
              "enum": [
                "UpdateRequest"
              ]
            },
            "version": {
              "type": "string"
            }
          }
        }
      ]
    },
    "CpuTempSensorConfig": {
      "type": "object",
      "required": [
        "enabled"
      ],
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "interval_s": {
          "type": [
            "number",
            "null"
          ],
          "format": "double"
        }
      }
    },
    "FcConfig": {
      "type": "object",
      "required": [
        "baudrate",
        "tty"
      ],
      "properties": {
        "baudrate": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0.0
        },
        "tty": {
          "type": "string"
        }
      }
    },
    "GeneralConfig": {
      "type": "object",
      "required": [
        "debug",
        "interface"
      ],
      "properties": {
        "debug": {
          "type": "boolean"
        },
        "interface": {
          "type": "string"
        }
      }
    },
    "LteSensorConfig": {
      "type": "object",
      "required": [
        "enabled",
        "neighbor_expiry_s"
      ],
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "interval_s": {
          "type": [
            "number",
            "null"
          ],
          "format": "double"
        },
        "neighbor_expiry_s": {
          "type": "number",
          "format": "double"
        }
      }
    },
    "MavlinkConfig": {
      "type": "object",
      "required": [
        "bs_sysid",
        "env_path",
        "fc",
        "gcs_compid",
        "gcs_ip",
        "gcs_sysid",
        "host",
        "iteration_period_ms",
        "local_mavlink_port",
        "protocol",
        "remote_mavlink_port",
        "self_compid",
        "self_sysid",
        "sniffer_sysid"
      ],
      "properties": {
        "bs_sysid": {
          "type": "integer",
          "format": "uint8",
          "minimum": 0.0
        },
        "env_path": {
          "type": "string"
        },
        "fc": {
          "$ref": "#/definitions/FcConfig"
        },
        "gcs_compid": {
          "type": "integer",
          "format": "uint8",
          "minimum": 0.0
        },
        "gcs_ip": {
          "type": "string"
        },
        "gcs_sysid": {
          "type": "integer",
          "format": "uint8",
          "minimum": 0.0
        },
        "host": {
          "type": "string"
        },
        "iteration_period_ms": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0.0
        },
        "local_mavlink_port": {
          "type": "integer",
          "format": "uint16",
          "minimum": 0.0
        },
        "protocol": {
          "type": "string"
        },
        "remote_mavlink_port": {
          "type": "integer",
          "format": "uint16",
          "minimum": 0.0
        },
        "self_compid": {
          "type": "integer",
          "format": "uint8",
          "minimum": 0.0
        },
        "self_sysid": {
          "type": "integer",
          "format": "uint8",
          "minimum": 0.0
        },
        "sniffer_sysid": {
          "type": "integer",
          "format": "uint8",
          "minimum": 0.0
        }
      }
    },
    "PingSensorConfig": {
      "type": "object",
      "required": [
        "enabled",
        "host"
      ],
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "host": {
          "type": "string"
        },
        "interval_s": {
          "type": [
            "number",
            "null"
          ],
          "format": "double"
        }
      }
    },
    "SafeConfig": {
      "description": "A sanitized view of the full `Config`, safe for MQTT exposure. TLS certificate paths are replaced with `\"***\"`.",
      "type": "object",
      "required": [
        "camera",
        "general",
        "mavlink",
        "mqtt",
        "sensors"
      ],
      "properties": {
        "camera": {
          "$ref": "#/definitions/CameraConfig"
        },
        "general": {
          "$ref": "#/definitions/GeneralConfig"
        },
        "mavlink": {
          "$ref": "#/definitions/MavlinkConfig"
        },
        "mqtt": {
          "$ref": "#/definitions/SafeMqttConfig"
        },
        "sensors": {
          "$ref": "#/definitions/SensorsConfig"
        }
      }
    },
    "SafeMqttConfig": {
      "description": "MQTT config with certificate paths redacted.",
      "type": "object",
      "required": [
        "ca_cert_path",
        "client_cert_path",
        "client_key_path",
        "enabled",
        "env_prefix",
        "host",
        "port",
        "telemetry_interval_s"
      ],
      "properties": {
        "ca_cert_path": {
          "type": "string"
        },
        "client_cert_path": {
          "type": "string"
        },
        "client_key_path": {
          "type": "string"
        },
        "enabled": {
          "type": "boolean"
        },
        "env_prefix": {
          "type": "string"
        },
        "host": {
          "type": "string"
        },
        "port": {
          "type": "integer",
          "format": "uint16",
          "minimum": 0.0
        },
        "telemetry_interval_s": {
          "type": "number",
          "format": "double"
        }
      }
    },
    "SensorsConfig": {
      "type": "object",
      "required": [
        "cpu_temp",
        "default_interval_s",
        "lte",
        "ping"
      ],
      "properties": {
        "cpu_temp": {
          "$ref": "#/definitions/CpuTempSensorConfig"
        },
        "default_interval_s": {
          "type": "number",
          "format": "double"
        },
        "lte": {
          "$ref": "#/definitions/LteSensorConfig"
        },
        "ping": {
          "$ref": "#/definitions/PingSensorConfig"
        }
      }
    }
  }
}
