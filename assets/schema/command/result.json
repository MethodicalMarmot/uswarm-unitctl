{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CommandResultMsg",
  "description": "Command result published on `.../cmnd/{name}/result`. The `data` field contains a tagged `CommandResultData` enum (omitted when None).",
  "type": "object",
  "required": [
    "ok",
    "ts",
    "uuid"
  ],
  "properties": {
    "data": {
      "anyOf": [
        {
          "$ref": "#/definitions/CommandResultData"
        },
        {
          "type": "null"
        }
      ]
    },
    "error": {
      "type": [
        "string",
        "null"
      ]
    },
    "ok": {
      "type": "boolean"
    },
    "ts": {
      "type": "string",
      "format": "date-time"
    },
    "uuid": {
      "type": "string"
    }
  },
  "definitions": {
    "CameraConfig": {
      "type": "object",
      "required": [
        "bitrate",
        "camera_type",
        "device",
        "env_path",
        "flip",
        "framerate",
        "gcs_ip",
        "height",
        "remote_video_port",
        "width"
      ],
      "properties": {
        "bitrate": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0.0
        },
        "camera_type": {
          "type": "string"
        },
        "device": {
          "type": "string"
        },
        "env_path": {
          "type": "string"
        },
        "flip": {
          "type": "integer",
          "format": "uint8",
          "minimum": 0.0
        },
        "framerate": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0.0
        },
        "gcs_ip": {
          "type": "string"
        },
        "height": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0.0
        },
        "remote_video_port": {
          "type": "integer",
          "format": "uint16",
          "minimum": 0.0
        },
        "width": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0.0
        }
      }
    },
    "CommandResultData": {
      "oneOf": [
        {
          "description": "Result for `get_config` — returns the sanitized configuration.",
          "type": "object",
          "required": [
            "config",
            "type"
          ],
          "properties": {
            "config": {
              "$ref": "#/definitions/SafeConfig"
            },
            "type": {
              "type": "string",
              "enum": [
                "GetConfig"
              ]
            }
          }
        },
        {
          "description": "Result for `config_update` (placeholder).",
          "type": "object",
          "required": [
            "fields_received",
            "message",
            "type"
          ],
          "properties": {
            "fields_received": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "message": {
              "type": "string"
            },
            "type": {
              "type": "string",
              "enum": [
                "ConfigUpdate"
              ]
            }
          }
        },
        {
          "description": "Result for `modem_commands`.",
          "type": "object",
          "required": [
            "command",
            "response",
            "type"
          ],
          "properties": {
            "command": {
              "type": "string"
            },
            "response": {
              "type": "string"
            },
            "type": {
              "type": "string",
              "enum": [
                "ModemCommands"
              ]
            }
          }
        },
        {
          "description": "Result for `update_request` (placeholder).",
          "type": "object",
          "required": [
            "message",
            "type",
            "version"
          ],
          "properties": {
            "message": {
              "type": "string"
            },
            "type": {
              "type": "string",
              "enum": [
                "UpdateRequest"
              ]
            },
            "version": {
              "type": "string"
            }
          }
        },
        {
          "description": "Result for `restart`. `ok` and `error` live on `CommandResultMsg`.",
          "type": "object",
          "required": [
            "target",
            "type"
          ],
          "properties": {
            "target": {
              "$ref": "#/definitions/RestartTarget"
            },
            "type": {
              "type": "string",
              "enum": [
                "Restart"
              ]
            }
          }
        }
      ]
    },
    "FcConfig": {
      "type": "object",
      "required": [
        "baudrate",
        "tty"
      ],
      "properties": {
        "baudrate": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0.0
        },
        "tty": {
          "type": "string"
        }
      }
    },
    "FluentbitConfig": {
      "type": "object",
      "required": [
        "config_path",
        "db_path",
        "enabled",
        "host",
        "port",
        "tls",
        "tls_verify"
      ],
      "properties": {
        "config_path": {
          "type": "string"
        },
        "db_path": {
          "type": "string"
        },
        "enabled": {
          "type": "boolean"
        },
        "host": {
          "type": "string"
        },
        "port": {
          "type": "integer",
          "format": "uint16",
          "minimum": 0.0
        },
        "systemd_filter": {
          "default": null,
          "type": [
            "array",
            "null"
          ],
          "items": {
            "type": "string"
          }
        },
        "tls": {
          "type": "boolean"
        },
        "tls_verify": {
          "type": "boolean"
        }
      }
    },
    "LteSensorConfig": {
      "type": "object",
      "required": [
        "enabled",
        "modem_type",
        "neighbor_expiry_s"
      ],
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "interval_s": {
          "type": [
            "number",
            "null"
          ],
          "format": "double"
        },
        "modem_type": {
          "type": "string"
        },
        "neighbor_expiry_s": {
          "type": "number",
          "format": "double"
        }
      }
    },
    "MavlinkConfig": {
      "type": "object",
      "required": [
        "bs_sysid",
        "env_path",
        "fc",
        "gcs_compid",
        "gcs_ip",
        "gcs_sysid",
        "host",
        "iteration_period_ms",
        "local_mavlink_port",
        "protocol",
        "remote_mavlink_port",
        "self_compid",
        "self_sysid",
        "sniffer_sysid"
      ],
      "properties": {
        "bs_sysid": {
          "type": "integer",
          "format": "uint8",
          "minimum": 0.0
        },
        "env_path": {
          "type": "string"
        },
        "fc": {
          "$ref": "#/definitions/FcConfig"
        },
        "gcs_compid": {
          "type": "integer",
          "format": "uint8",
          "minimum": 0.0
        },
        "gcs_ip": {
          "type": "string"
        },
        "gcs_sysid": {
          "type": "integer",
          "format": "uint8",
          "minimum": 0.0
        },
        "host": {
          "type": "string"
        },
        "iteration_period_ms": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0.0
        },
        "local_mavlink_port": {
          "type": "integer",
          "format": "uint16",
          "minimum": 0.0
        },
        "protocol": {
          "type": "string"
        },
        "remote_mavlink_port": {
          "type": "integer",
          "format": "uint16",
          "minimum": 0.0
        },
        "self_compid": {
          "type": "integer",
          "format": "uint8",
          "minimum": 0.0
        },
        "self_sysid": {
          "type": "integer",
          "format": "uint8",
          "minimum": 0.0
        },
        "sniffer_sysid": {
          "type": "integer",
          "format": "uint8",
          "minimum": 0.0
        }
      }
    },
    "PingSensorConfig": {
      "type": "object",
      "required": [
        "enabled",
        "host"
      ],
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "host": {
          "type": "string"
        },
        "interval_s": {
          "type": [
            "number",
            "null"
          ],
          "format": "double"
        }
      }
    },
    "RestartTarget": {
      "description": "Target unit/operation for a `restart` command.",
      "type": "string",
      "enum": [
        "camera",
        "mavlink",
        "modem",
        "unitctl",
        "reboot"
      ]
    },
    "SafeConfig": {
      "description": "A sanitized view of the full `Config`, safe for MQTT exposure. TLS certificate paths in `general` are replaced with `\"***\"`.",
      "type": "object",
      "required": [
        "camera",
        "fluentbit",
        "general",
        "mavlink",
        "mqtt",
        "sensors"
      ],
      "properties": {
        "camera": {
          "$ref": "#/definitions/CameraConfig"
        },
        "fluentbit": {
          "$ref": "#/definitions/FluentbitConfig"
        },
        "general": {
          "$ref": "#/definitions/SafeGeneralConfig"
        },
        "mavlink": {
          "$ref": "#/definitions/MavlinkConfig"
        },
        "mqtt": {
          "$ref": "#/definitions/SafeMqttConfig"
        },
        "sensors": {
          "$ref": "#/definitions/SensorsConfig"
        }
      }
    },
    "SafeGeneralConfig": {
      "description": "General config with TLS cert paths redacted.",
      "type": "object",
      "required": [
        "debug",
        "env_dir",
        "interface"
      ],
      "properties": {
        "ca_cert_path": {
          "type": [
            "string",
            "null"
          ]
        },
        "client_cert_path": {
          "type": [
            "string",
            "null"
          ]
        },
        "client_key_path": {
          "type": [
            "string",
            "null"
          ]
        },
        "debug": {
          "type": "boolean"
        },
        "env_dir": {
          "type": "string"
        },
        "interface": {
          "type": "string"
        }
      }
    },
    "SafeMqttConfig": {
      "description": "MQTT config (no secrets — cert paths now live in `general`).",
      "type": "object",
      "required": [
        "enabled",
        "env_prefix",
        "host",
        "port",
        "telemetry_interval_s"
      ],
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "env_prefix": {
          "type": "string"
        },
        "host": {
          "type": "string"
        },
        "port": {
          "type": "integer",
          "format": "uint16",
          "minimum": 0.0
        },
        "telemetry_interval_s": {
          "type": "number",
          "format": "double"
        }
      }
    },
    "SensorsConfig": {
      "type": "object",
      "required": [
        "default_interval_s",
        "lte",
        "ping",
        "system"
      ],
      "properties": {
        "default_interval_s": {
          "type": "number",
          "format": "double"
        },
        "lte": {
          "$ref": "#/definitions/LteSensorConfig"
        },
        "ping": {
          "$ref": "#/definitions/PingSensorConfig"
        },
        "system": {
          "$ref": "#/definitions/SystemSensorConfig"
        }
      }
    },
    "SystemSensorConfig": {
      "type": "object",
      "required": [
        "enabled"
      ],
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "interval_s": {
          "type": [
            "number",
            "null"
          ],
          "format": "double"
        }
      }
    }
  }
}
