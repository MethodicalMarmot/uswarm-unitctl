{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "TelemetryEnvelope",
  "description": "Shared envelope carrying a UTC timestamp for all telemetry types. The `data` field contains a tagged `TelemetryData` enum, producing JSON like: `{\"ts\": \"...\", \"data\": {\"type\": \"Ping\", \"reachable\": true, ...}}`",
  "type": "object",
  "required": [
    "data",
    "ts"
  ],
  "properties": {
    "data": {
      "$ref": "#/definitions/TelemetryData"
    },
    "ts": {
      "type": "string",
      "format": "date-time"
    }
  },
  "definitions": {
    "CameraFormat": {
      "type": "object",
      "required": [
        "fourcc",
        "height",
        "width"
      ],
      "properties": {
        "fourcc": {
          "type": "string"
        },
        "height": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0.0
        },
        "width": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0.0
        }
      }
    },
    "CameraInfo": {
      "type": "object",
      "required": [
        "device",
        "formats"
      ],
      "properties": {
        "device": {
          "type": "string"
        },
        "driver": {
          "type": [
            "string",
            "null"
          ]
        },
        "formats": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/CameraFormat"
          }
        },
        "name": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "DiskUsage": {
      "type": "object",
      "required": [
        "available_bytes",
        "mount_point",
        "total_bytes"
      ],
      "properties": {
        "available_bytes": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0.0
        },
        "mount_point": {
          "type": "string"
        },
        "total_bytes": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0.0
        }
      }
    },
    "LoadAverage": {
      "type": "object",
      "required": [
        "fifteen",
        "five",
        "one"
      ],
      "properties": {
        "fifteen": {
          "type": "number",
          "format": "double"
        },
        "five": {
          "type": "number",
          "format": "double"
        },
        "one": {
          "type": "number",
          "format": "double"
        }
      }
    },
    "LteNeighborCell": {
      "description": "A single LTE neighbor cell observation.",
      "type": "object",
      "required": [
        "earfcn",
        "pcid",
        "rsrp",
        "rsrq",
        "rssi",
        "rssnr"
      ],
      "properties": {
        "earfcn": {
          "type": "integer",
          "format": "int32"
        },
        "pcid": {
          "type": "integer",
          "format": "int32"
        },
        "rsrp": {
          "type": "integer",
          "format": "int32"
        },
        "rsrq": {
          "type": "integer",
          "format": "int32"
        },
        "rssi": {
          "type": "integer",
          "format": "int32"
        },
        "rssnr": {
          "type": "integer",
          "format": "int32"
        }
      }
    },
    "LteSignalQuality": {
      "description": "LTE signal quality measurements (serving cell only, no neighbors).\n\nDefined in the messages module and re-exported by `sensors::lte`. Published as part of `LteTelemetry` within `TelemetryData::Lte`.",
      "type": "object",
      "required": [
        "earfcn",
        "pcid",
        "rsrp",
        "rsrq",
        "rssi",
        "rssnr",
        "tx_power"
      ],
      "properties": {
        "earfcn": {
          "type": "integer",
          "format": "int32"
        },
        "pcid": {
          "type": "integer",
          "format": "int32"
        },
        "rsrp": {
          "type": "integer",
          "format": "int32"
        },
        "rsrq": {
          "type": "integer",
          "format": "int32"
        },
        "rssi": {
          "type": "integer",
          "format": "int32"
        },
        "rssnr": {
          "type": "integer",
          "format": "int32"
        },
        "tx_power": {
          "type": "integer",
          "format": "int32"
        }
      }
    },
    "NetworkInterfaceTelemetry": {
      "type": "object",
      "required": [
        "ipv4",
        "name",
        "rx_bps",
        "tx_bps"
      ],
      "properties": {
        "ipv4": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "name": {
          "type": "string"
        },
        "rx_bps": {
          "description": "Bits per second since the previous sensor tick.",
          "type": "integer",
          "format": "uint64",
          "minimum": 0.0
        },
        "tx_bps": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0.0
        }
      }
    },
    "RamUsage": {
      "type": "object",
      "required": [
        "available_bytes",
        "total_bytes",
        "used_bytes"
      ],
      "properties": {
        "available_bytes": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0.0
        },
        "total_bytes": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0.0
        },
        "used_bytes": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0.0
        }
      }
    },
    "TelemetryData": {
      "oneOf": [
        {
          "description": "ICMP ping telemetry.",
          "type": "object",
          "required": [
            "latency_ms",
            "loss_percent",
            "reachable",
            "type"
          ],
          "properties": {
            "latency_ms": {
              "type": "number",
              "format": "double"
            },
            "loss_percent": {
              "type": "integer",
              "format": "uint8",
              "minimum": 0.0
            },
            "reachable": {
              "type": "boolean"
            },
            "type": {
              "type": "string",
              "enum": [
                "Ping"
              ]
            }
          }
        },
        {
          "description": "LTE serving-cell signal quality and neighbor cells.",
          "type": "object",
          "required": [
            "imsi",
            "neighbors",
            "signal",
            "type"
          ],
          "properties": {
            "imsi": {
              "type": "string"
            },
            "neighbors": {
              "type": "array",
              "items": {
                "$ref": "#/definitions/LteNeighborCell"
              }
            },
            "signal": {
              "$ref": "#/definitions/LteSignalQuality"
            },
            "type": {
              "type": "string",
              "enum": [
                "Lte"
              ]
            }
          }
        },
        {
          "description": "Aggregate host telemetry: CPU temp/usage, memory, disks, load, uptime, network interfaces (with bandwidth + addresses), and connected cameras.",
          "type": "object",
          "required": [
            "cameras",
            "cpu_usage_percent",
            "disks",
            "load_avg",
            "network_interfaces",
            "ram",
            "type",
            "uptime_s"
          ],
          "properties": {
            "cameras": {
              "type": "array",
              "items": {
                "$ref": "#/definitions/CameraInfo"
              }
            },
            "cpu_temperature_c": {
              "description": "CPU temperature in degrees Celsius. `None` if the sysfs read failed.",
              "type": [
                "number",
                "null"
              ],
              "format": "double"
            },
            "cpu_usage_percent": {
              "description": "Aggregate CPU usage across all cores, 0..100.",
              "type": "number",
              "format": "float"
            },
            "disks": {
              "type": "array",
              "items": {
                "$ref": "#/definitions/DiskUsage"
              }
            },
            "load_avg": {
              "$ref": "#/definitions/LoadAverage"
            },
            "network_interfaces": {
              "type": "array",
              "items": {
                "$ref": "#/definitions/NetworkInterfaceTelemetry"
              }
            },
            "ram": {
              "$ref": "#/definitions/RamUsage"
            },
            "type": {
              "type": "string",
              "enum": [
                "System"
              ]
            },
            "uptime_s": {
              "type": "integer",
              "format": "uint64",
              "minimum": 0.0
            }
          }
        }
      ]
    }
  }
}
