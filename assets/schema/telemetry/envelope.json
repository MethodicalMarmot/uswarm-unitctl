{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "TelemetryEnvelope",
  "description": "Shared envelope carrying a UTC timestamp for all telemetry types. The `data` field contains a tagged `TelemetryData` enum, producing JSON like: `{\"ts\": \"...\", \"data\": {\"type\": \"Ping\", \"reachable\": true, ...}}`",
  "type": "object",
  "required": [
    "data",
    "ts"
  ],
  "properties": {
    "data": {
      "$ref": "#/definitions/TelemetryData"
    },
    "ts": {
      "type": "string",
      "format": "date-time"
    }
  },
  "definitions": {
    "LteNeighborCell": {
      "description": "A single LTE neighbor cell observation.",
      "type": "object",
      "required": [
        "earfcn",
        "pcid",
        "rsrp",
        "rsrq",
        "rssi",
        "rssnr"
      ],
      "properties": {
        "earfcn": {
          "type": "integer",
          "format": "int32"
        },
        "pcid": {
          "type": "integer",
          "format": "int32"
        },
        "rsrp": {
          "type": "integer",
          "format": "int32"
        },
        "rsrq": {
          "type": "integer",
          "format": "int32"
        },
        "rssi": {
          "type": "integer",
          "format": "int32"
        },
        "rssnr": {
          "type": "integer",
          "format": "int32"
        }
      }
    },
    "LteSignalQuality": {
      "description": "LTE signal quality measurements (serving cell only, no neighbors).\n\nDefined in the messages module and re-exported by `sensors::lte`. Published as part of `LteTelemetry` within `TelemetryData::Lte`.",
      "type": "object",
      "required": [
        "earfcn",
        "pcid",
        "rsrp",
        "rsrq",
        "rssi",
        "rssnr",
        "tx_power"
      ],
      "properties": {
        "earfcn": {
          "type": "integer",
          "format": "int32"
        },
        "pcid": {
          "type": "integer",
          "format": "int32"
        },
        "rsrp": {
          "type": "integer",
          "format": "int32"
        },
        "rsrq": {
          "type": "integer",
          "format": "int32"
        },
        "rssi": {
          "type": "integer",
          "format": "int32"
        },
        "rssnr": {
          "type": "integer",
          "format": "int32"
        },
        "tx_power": {
          "type": "integer",
          "format": "int32"
        }
      }
    },
    "TelemetryData": {
      "oneOf": [
        {
          "description": "ICMP ping telemetry.",
          "type": "object",
          "required": [
            "latency_ms",
            "loss_percent",
            "reachable",
            "type"
          ],
          "properties": {
            "latency_ms": {
              "type": "number",
              "format": "double"
            },
            "loss_percent": {
              "type": "integer",
              "format": "uint8",
              "minimum": 0.0
            },
            "reachable": {
              "type": "boolean"
            },
            "type": {
              "type": "string",
              "enum": [
                "Ping"
              ]
            }
          }
        },
        {
          "description": "LTE serving-cell signal quality and neighbor cells.",
          "type": "object",
          "required": [
            "neighbors",
            "signal",
            "type"
          ],
          "properties": {
            "neighbors": {
              "type": "array",
              "items": {
                "$ref": "#/definitions/LteNeighborCell"
              }
            },
            "signal": {
              "$ref": "#/definitions/LteSignalQuality"
            },
            "type": {
              "type": "string",
              "enum": [
                "Lte"
              ]
            }
          }
        },
        {
          "description": "CPU temperature telemetry.",
          "type": "object",
          "required": [
            "temperature_c",
            "type"
          ],
          "properties": {
            "temperature_c": {
              "type": "number",
              "format": "double"
            },
            "type": {
              "type": "string",
              "enum": [
                "CpuTemp"
              ]
            }
          }
        }
      ]
    }
  }
}
