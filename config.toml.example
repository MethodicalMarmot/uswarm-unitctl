# unitctl configuration
# Copy this file to config.toml and adjust as needed.
# All fields are required.

[general]
debug = false
interface = "eth0"
# Directory for runtime state files (e.g. pending-restart-uuid for self-restart ack)
env_dir = "/var/run/unitctl"

[mavlink]
protocol = "tcpout"
host = "127.0.0.1"
local_mavlink_port = 5760
remote_mavlink_port = 14550
self_sysid = 1               # MAVLink system ID for this unit; set to 0 to autodiscover (min FC sysid from sniffer)
self_compid = 10
gcs_sysid = 255
gcs_compid = 190
sniffer_sysid = 199
bs_sysid = 200
iteration_period_ms = 10
# GCS IP address written to mavlink env file
gcs_ip = "10.101.0.1"
# Path where mavlink env file is written at startup (read by mavlink-routerd)
env_path = "/etc/mavlink.env"

[mavlink.fc]
tty = "/dev/ttyFC"
baudrate = 57600

# Camera env file settings (written at startup, read by camera streamer)
[camera]
gcs_ip = "10.101.0.1"
# Path where camera env file is written at startup
env_path = "/etc/camera.env"
remote_video_port = 5600
width = 640
height = 360
framerate = 60
bitrate = 1664000
# Camera flip: 0=none, 1=horizontal, 2=vertical, 3=both
flip = 0
camera_type = "rpi"
device = "/dev/video1"

[sensors]
default_interval_s = 5.0

[sensors.ping]
enabled = true
# interval_s = 1.0
host = "10.45.0.2"

[sensors.lte]
enabled = true
# interval_s = 1.0
neighbor_expiry_s = 30.0
# Modem backend: "dbus" (real ModemManager) or "fake" (deterministic simulator)
modem_type = "dbus"

[sensors.system]
enabled = true
# interval_s = 5.0   # falls back to sensors.default_interval_s

# MQTT communication with central server
# Publishes sensor telemetry (LTE, ping, system) and receives commands
# (config_update, get_config, update_request, modem_commands).
# Authentication uses mutual TLS; the node ID is extracted from the client
# certificate's CN field.
# Topic structure: {env_prefix}/nodes/{nodeId}/telemetry/{name}
#                  {env_prefix}/nodes/{nodeId}/cmnd/{cmd}/{in|status|result}
[mqtt]
enabled = false
host = "mqtt.example.com"
port = 8883
# Mutual TLS certificate paths (node ID extracted from client certificate CN)
ca_cert_path = "/etc/unitctl/certs/ca.pem"
client_cert_path = "/etc/unitctl/certs/client.pem"
client_key_path = "/etc/unitctl/certs/client.key"
# Environment prefix for MQTT topics (e.g. "prod", "staging")
env_prefix = "prod"
# Telemetry publish interval in seconds.
# Should be >= sensors.default_interval_s (and any per-sensor interval_s
# override): publishing faster than samples are taken just republishes the
# previous reading with a fresh timestamp.
telemetry_interval_s = 5.0
