{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CommandStatus",
  "description": "Status update published on `.../cmnd/{name}/status`.",
  "type": "object",
  "required": [
    "state",
    "ts",
    "uuid"
  ],
  "properties": {
    "state": {
      "$ref": "#/definitions/CommandState"
    },
    "ts": {
      "type": "string",
      "format": "date-time"
    },
    "uuid": {
      "type": "string"
    }
  },
  "definitions": {
    "CommandState": {
      "description": "Command lifecycle state.",
      "type": "string",
      "enum": [
        "accepted",
        "in_progress",
        "completed",
        "failed",
        "rejected",
        "expired",
        "superseded"
      ]
    }
  }
}