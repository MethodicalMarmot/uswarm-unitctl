# unitctl configuration
# Copy this file to config.toml and adjust as needed.
# All fields are required.

[general]
debug = false

[mavlink]
protocol = "tcpout"
host = "127.0.0.1"
port = 5760
self_sysid = 1
self_compid = 10
gcs_sysid = 255
gcs_compid = 190
sniffer_sysid = 199
bs_sysid = 200
iteration_period_ms = 10

[mavlink.fc]
tty = "/dev/ttyFC"
baudrate = 57600

[sensors]
default_interval_s = 1.0

[sensors.ping]
enabled = true
# interval_s = 1.0
host = "10.45.0.2"
interface = ""

[sensors.lte]
enabled = true
# interval_s = 1.0
neighbor_expiry_s = 30.0

[sensors.cpu_temp]
enabled = true
# interval_s = 5.0
